{
    "name": "GitHub Copilot Starter",
    "image": "mcr.microsoft.com/devcontainers/anaconda:1-3",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        },
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "ms-python.python"
            ]
        }
    }
}
